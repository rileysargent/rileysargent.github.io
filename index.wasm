move_left:
        i32.const       0
        f32.load        sledX
        f32.const       0x1p-1
        f32.sub 
        local.set       0
        i32.const       0
        local.get       0
        f32.store       sledX
        return
        end_function

move_right:
        i32.const       0
        f32.load        sledX
        f32.const       0x1p-1
        f32.add 
        local.set       0
        i32.const       0
        local.get       0
        f32.store       sledX
        return
        end_function

get_sled_x:
        i32.const       0
        f32.load        sledX
        return
        end_function

get_gifts:
        i32.const       0
        i32.load        giftCount
        return
        end_function

game_loop:
        block           
        i32.const       0
        f32.load        sledX
        f32.const       -0x1.ep3
        f32.lt  
        i32.const       1
        i32.and 
        i32.eqz
        br_if           0
        f32.const       -0x1.ep3
        local.set       0
        i32.const       0
        local.get       0
        f32.store       sledX
        end_block
        block           
        i32.const       0
        f32.load        sledX
        f32.const       0x1.ep3
        f32.gt  
        i32.const       1
        i32.and 
        i32.eqz
        br_if           0
        f32.const       0x1.ep3
        local.set       1
        i32.const       0
        local.get       1
        f32.store       sledX
        end_block
        return
        end_function

sledX:
        .int32  0x00000000

giftCount:
